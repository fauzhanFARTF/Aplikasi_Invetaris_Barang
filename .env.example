APP_NAME="SIMANTAP — Diskominfo Kab. Tangerang"
APP_URL="http://localhost:8080"
APP_ENV="production"
APP_TZ="Asia/Jakarta"

# JWT — WAJIB ganti dengan random string minimal 32 karakter
JWT_SECRET="ganti-secret-ini-dengan-string-acak-yang-panjang"
JWT_TTL_SEC=28800

# Cloudflare Turnstile (CAPTCHA anti-bot di halaman login).
# Kosongkan keduanya untuk MENONAKTIFKAN. Isi dari: Cloudflare Dashboard > Turnstile > Add site.
TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""

# Database
DB_HOST="127.0.0.1"
DB_PORT=3306
DB_NAME="bmn_streaming"
DB_USER="root"
DB_PASS=""
# Opsional: gunakan unix socket (lebih cepat di lokal). Kosongkan jika pakai TCP.
DB_SOCKET=""

# Mail — mode 'log' menyimpan email ke tabel email_logs di database (tidak mengirim).
# Ganti ke 'smtp' + tambahkan MAIL_HOST/PORT/USER/PASS + modifikasi src/Mailer.php.
MAIL_MODE="log"
MAIL_FROM_NAME="SIMANTAP"
MAIL_FROM_EMAIL="noreply@diskominfo.tangerangkab.go.id"
